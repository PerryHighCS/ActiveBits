{
  "name": "activebits-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "npm run test:unit",
    "test:unit": "sh -c 'set -e; files=$(find src \\( -name \"*.test.ts\" -o -name \"*.test.tsx\" \\) -print); if [ -z \"$files\" ]; then echo \"No client tests found\"; exit 0; fi; node --import tsx --test $files'",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-jsdoc": "^62.9.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.12"
  }
}
