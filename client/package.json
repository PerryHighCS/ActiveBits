{
  "name": "activebits-client",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "test": "npm run test:unit",
    "test:unit": "sh -c 'set -e; files=$(find src \\( -name \"*.test.ts\" -o -name \"*.test.tsx\" \\) -print); if [ -z \"$files\" ]; then echo \"No client tests found\"; exit 0; fi; node --import tsx --import ../scripts/jsx-loader-register.mjs --test $files'",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.0",
    "react-zxing": "^3.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "ws": "^8.21.0",
    "zxing-wasm": "^3.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.5.0",
    "eslint-plugin-jsdoc": "^63.0.7",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
